# Copy to .env and set real values. Server-only (not in Vite define).

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# Session encryption — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=<32-byte random hex>

# App URL — use https://your-domain.com in production (for OAuth callback)
APP_URL=http://localhost:3000

# Supabase Postgres (used for all app data + sessions + TTS cache).
# Replace [YOUR-PASSWORD] with the real database password before running the app.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ykaudwlislohrwoephga.supabase.co:5432/postgres

# Gemini API (for TTS/quiz). Can be exposed to client for live features.
GEMINI_API_KEY=

# AI Provider for answer evaluation. "gemini" (default) or "local" (Ollama).
# AI_PROVIDER=gemini
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:4b
